cat > .gitignore << 'EOF'
# Python virtual environments
venv/
.venv/
backend/venv/
backend/.venv/

# Python cache
__pycache__/
*.pyc

# Node
node_modules/
dist/

# Env / secrets
.env
.env.*
*.pem

# OS
.DS_Store
EOF

# Model files -- too large for GitHub
model_training/models/
model_training/data/raw/
model_training/data/processed/

# Frontend dependencies
frontend/vite-project/node_modules/


*.pt
*.safetensors
checkpoints/
